{
  "description": "Detects Unreal Engine 5 projects and provides context to Claude",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-ue5-project.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
